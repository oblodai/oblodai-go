# Учётные данные Oblodai. ТОЛЬКО для серверной среды — секрет никогда не должен попадать
# в браузер или мобильное приложение. Скопируйте в `.env` и подставьте свои значения.

# Обязательные:
OBLODAI_PUBLIC_ID=oblodai_public_id_here
OBLODAI_SECRET=oblodai_secret_here

# Необязательно — переопределяет базовый URL API (по умолчанию https://api.oblodai.com):
# OBLODAI_BASE_URL=https://api.oblodai.com
